{
  "LoggingOptions": {
    "LogLevel": "Information",
    "ConsoleEnabled": true,
    "FileEnabled": true,
    "LogPath": "Logs/app-.log"
  },

  "JwtOptions": {
    "AccessCookieName": "access",
    "RefreshCookieName": "refresh",
    "UserIdCookieName": "userId",
    "SessionCookieName": "sessionId",
    "Issuer": "hack-api",
    "Audience": "hack-clients",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 1
  },

  "QrOptions": {
    "ExpirationSeconds" : 300
  },

  "ConnectionOptions": {
//    "DatabaseConnectionTemplate": "Host=postgres;Port=5432;Database=hackaton;Username=postgres;Password={0}",
//    "DatabaseConnectionTemplate": "Host=localhost;Port=5432;Database=hackaton;Username=postgres;Password={0}",
    "DatabaseConnectionTemplate": "Host=localhost;Port=5433;Database=hackaton;Username=postgres;Password={0}",
    "RedisConnectionTemplate": "redis:6379,password={0},defaultDatabase=0,abortConnect=false,ssl=false",
    "RedisInstanceName": "Hackaton:"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "VerificationOptions": {
    "EmailExpirationMinutes": 30,
    "ConfirmEmailLink": "shkets.ru",
    "ResetPasswordLink": "shkets.ru"
  },

  "TransactionOptions": {
    "MaxRetryCount": 3,
    "EnableRetryOnFailure": true,
    "UseExponentialBackoff": true,
    "FixedDelayMs": 200
  }, 
  
  "ApiKeyOptions": {
    "Header": "X-Api-Key",
    "UseApiKeyAccess": true
  },

  "SmtpOptions": {
    "Host": "mail.netangels.ru",
    "Name": "Шкеты",
    "Port": 587,

    "MaxRetryAttempts": 3,
    "UsePortAndSsl": false,
    "TimeoutSeconds": 30,
    "RetryDelaySeconds": 5
  },

  "EmailTemplateOptions": {
    "ResourcesPath": "../Resources",
//    "ResourcesPath": "/app/Resources",
    "EmailTemplateWithButtonFileName": "EmailTemplateWithButton.html"
  },

  "AllowedHosts": "*"
}
