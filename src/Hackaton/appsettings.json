{
  "LoggingSettings": {
    "LogLevel": "Information",
    "ConsoleEnabled": true,
    "FileEnabled": true,
    "LogPath": "Logs/app-.log"
  },
  "JwtSettings": {
    "AccessCookieName": "access",
    "RefreshCookieName": "refresh",
    "UserIdCookieName": "userId",
    "SessionCookieName": "sessionId",
    "Issuer": "hack-api",
    "Audience": "hack-clients",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 1
  },
  "ConnectionStrings": {
    "Database": "Host=postgres;Port=5432;Database=hackaton;Username=postgres;Password={0}",
    "Redis": "{0}@localhost:6379,defaultDatabase=0,abortConnect=false,ssl=false"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
}
